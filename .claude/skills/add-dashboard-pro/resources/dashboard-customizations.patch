+      var debounceTimer = null;
+      function updatePreview() {
+        var expr = input.value.trim();
+        if (!expr) { preview.textContent = '(no schedule)'; preview.classList.remove('error'); return; }
+        cronDescribe(expr).then(function(text) {
+          if (text) {
+            preview.textContent = text;
+            preview.classList.remove('error');
+          } else {
+            preview.textContent = 'invalid cron expression';
+            preview.classList.add('error');
+          }
+        });
+      }
+      input.addEventListener('input', function() {
+        if (debounceTimer) clearTimeout(debounceTimer);
+        debounceTimer = setTimeout(updatePreview, 150);
+      });
+      updatePreview();
+      input.focus();
+      var ce = document.getElementById('task-drawer-cron-edit');
+      if (ce) ce.style.display = 'none';
+      document.getElementById('task-drawer-cron-save').addEventListener('click', async function() {
+        var newCron = input.value.trim();
+        try {
+          await mutate('PATCH', '/api/tasks/' + encodeURIComponent(t.id), {
+            sessionId: t.sessionId,
+            recurrence: newCron === '' ? null : newCron,
+          });
+          await refreshTasks();
+        } catch (e) {
+          var err = document.getElementById('task-drawer-cron-error');
+          if (err) err.textContent = e.message;
+        }
+      });
+      document.getElementById('task-drawer-cron-cancel').addEventListener('click', function() {
+        paintDrawer(t);
+      });
+    }
+
+    function closeDrawer() {
+      state.drawerTaskId = null;
+      var drawer = document.getElementById('task-drawer');
+      var bd = document.getElementById('task-drawer-backdrop');
+      if (drawer) {
+        drawer.classList.remove('open');
+        setTimeout(function() { drawer.hidden = true; }, 240);
+      }
+      if (bd) {
+        bd.classList.remove('open');
+        setTimeout(function() { bd.hidden = true; }, 240);
+      }
+    }
+    </script>
+  `);
+}
+/**
+ * Server-side cron describer used by /api/cron/describe.
+ * Returns a human-readable string or null on parse failure.
+ */
+export function cronDescribe(expr) {
+    if (typeof expr !== 'string' || expr.length === 0) return null;
+    try {
+        return cronstrue.toString(expr);
+    } catch {
+        return null;
+    }
+}
