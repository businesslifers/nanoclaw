+import { layout } from '../layout.js';
+export function auditPage() {
+    return layout('Audit', '/dashboard/audit', `
+    <div id="audit-page" class="audit-v2"><div class="ov-loading">Loading…</div></div>
+    <script>
+    (async () => {
+      try {
+        const rows = await api('/api/audit');
+        renderAudit(rows || []);
+      } catch (e) {
+        document.getElementById('audit-page').innerHTML = '<div class="ov-loading">Error: ' + esc(e.message) + '</div>';
+      }
+    })();
+
+    function renderAudit(rows) {
+      var actions = Array.from(new Set(rows.map(function(r){ return r.action; }))).sort();
+      var targets = Array.from(new Set(rows.map(function(r){ return r.target_type; }))).sort();
+
+      var headerHtml =
+        '<header class="ov-header">' +
+          '<div class="ov-header-title">' +
+            '<h2>Audit Log</h2>' +
+            '<p class="ov-subtitle">Every dashboard write — who, what, when, before → after</p>' +
+          '</div>' +
+        '</header>';
+
+      var toolbarHtml =
+        '<div class="audit-toolbar">' +
+          '<input type="search" id="audit-search" class="audit-search" placeholder="Search actor / target / action…" autocomplete="off">' +
+          '<select id="audit-filter-action" class="audit-filter">' +
+            '<option value="">All actions</option>' +
+            actions.map(function(a){ return '<option value="' + esc(a) + '">' + esc(a) + '</option>'; }).join('') +
+          '</select>' +
+          '<select id="audit-filter-target" class="audit-filter">' +
+            '<option value="">All targets</option>' +
+            targets.map(function(t){ return '<option value="' + esc(t) + '">' + esc(t) + '</option>'; }).join('') +
+          '</select>' +
+          '<span class="audit-count" id="audit-count">' + rows.length + ' rows</span>' +
+        '</div>';
+
+      if (rows.length === 0) {
+        document.getElementById('audit-page').innerHTML =
+          headerHtml + toolbarHtml + '<div class="ov-loading">No audit rows yet — dashboard writes will appear here.</div>';
+        return;
+      }
+
+      var tableHtml =
+        '<table class="audit-table">' +
+          '<thead><tr>' +
+            '<th>When</th>' +
+            '<th>Actor</th>' +
+            '<th>Action</th>' +
+            '<th>Target</th>' +
+            '<th>Before</th>' +
+            '<th>After</th>' +
+          '</tr></thead>' +
+          '<tbody id="audit-tbody">' +
+            rows.map(renderRow).join('') +
+          '</tbody>' +
+        '</table>';
+
+      document.getElementById('audit-page').innerHTML = headerHtml + toolbarHtml + tableHtml;
+      wireFilters(rows);
+    }
+
+    function renderRow(r) {
+      return '<tr class="audit-row" data-action="' + esc(r.action) + '" data-target="' + esc(r.target_type) + '" data-search="' +
+        esc((r.actor_user_id + ' ' + r.target_id + ' ' + r.action).toLowerCase()) + '">' +
+        '<td class="audit-ts" title="' + esc(r.ts) + '">' + esc(timeAgo(r.ts)) + '</td>' +
+        '<td class="audit-actor">' + esc(r.actor_user_id) + '</td>' +
+        '<td><span class="audit-action-pill">' + esc(r.action) + '</span></td>' +
+        '<td class="audit-target"><span class="audit-target-type">' + esc(r.target_type) + '</span> ' +
+          '<span class="audit-target-id">' + esc(r.target_id) + '</span></td>' +
+        '<td class="audit-json">' + renderJson(r.before_json) + '</td>' +
+        '<td class="audit-json">' + renderJson(r.after_json) + '</td>' +
+      '</tr>';
+    }
+
+    function renderJson(s) {
+      if (s == null) return '<span class="audit-empty">—</span>';
+      try { return '<code>' + esc(JSON.stringify(JSON.parse(s))) + '</code>'; }
+      catch (e) { return '<code>' + esc(String(s)) + '</code>'; }
+    }
+
+    function wireFilters() {
+      var search = document.getElementById('audit-search');
+      var actionSel = document.getElementById('audit-filter-action');
+      var targetSel = document.getElementById('audit-filter-target');
+      var count = document.getElementById('audit-count');
+      function apply() {
+        var q = (search.value || '').trim().toLowerCase();
+        var act = actionSel.value;
+        var tgt = targetSel.value;
+        var rows = document.querySelectorAll('#audit-tbody .audit-row');
+        var visible = 0;
+        rows.forEach(function(row) {
+          var rAct = row.getAttribute('data-action');
+          var rTgt = row.getAttribute('data-target');
+          var rSearch = row.getAttribute('data-search') || '';
+          var keep = (!act || rAct === act) && (!tgt || rTgt === tgt) && (!q || rSearch.indexOf(q) >= 0);
+          row.style.display = keep ? '' : 'none';
+          if (keep) visible++;
+        });
+        count.textContent = visible + (visible === rows.length ? ' rows' : ' of ' + rows.length + ' rows');
+      }
+      search.addEventListener('input', apply);
+      actionSel.addEventListener('change', apply);
+      targetSel.addEventListener('change', apply);
+    }
+    </script>
+  `);
+}
