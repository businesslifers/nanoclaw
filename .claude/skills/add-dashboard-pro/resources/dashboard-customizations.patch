+  // ---- Landing (renders index.md) ----
+
+  async function loadLanding(id) {
+    try {
+      var w = await api('/api/wikis/' + encodeURIComponent(id));
+      if (!w) {
+        document.getElementById('wk-root').innerHTML =
+          '<div class="ov-loading">Wiki not found</div>';
+        return;
+      }
+      var html = '';
+      try {
+        html = await api('/api/wikis/' + encodeURIComponent(id) + '/page?path=index.md');
+      } catch (_) {
+        html = '<p class="wk-muted">index.md could not be loaded.</p>';
+      }
+      document.getElementById('wk-root').innerHTML =
+        '<div class="wk-page">' +
+          renderSidebar(w, 'index.md') +
+          '<div class="wk-main">' +
+            renderInnerChrome(w) +
+            '<article class="wk-body">' + html + '</article>' +
+            renderGlance(w) +
+          '</div>' +
+        '</div>';
+      attachCopyButtons();
+    } catch (e) {
+      document.getElementById('wk-root').innerHTML =
+        '<div class="ov-loading">Error: ' + esc(e.message) + '</div>';
+    }
+  }
+
+  // ---- Page (specific file) ----
+
+  async function loadPage(id, p) {
+    try {
+      var both = await Promise.all([
+        api('/api/wikis/' + encodeURIComponent(id)),
+        api('/api/wikis/' + encodeURIComponent(id) + '/page?path=' + encodeURIComponent(p)),
+      ]);
+      var w = both[0];
+      var html = both[1]; // server-rendered HTML
+
+      document.getElementById('wk-root').innerHTML =
+        '<div class="wk-page">' +
+          renderSidebar(w, p) +
+          '<div class="wk-main">' +
+            renderInnerChrome(w) +
+            '<article class="wk-body">' + html + '</article>' +
+          '</div>' +
+        '</div>';
+      attachCopyButtons();
+    } catch (e) {
+      document.getElementById('wk-root').innerHTML =
+        '<div class="ov-loading">Error: ' + esc(e.message) + '</div>';
+    }
+  }
