+      '<div class="wk-tree-section">' + subdirs.map(nodeHtml).join('') + '</div>' +
+      (logLink ? '<div class="wk-sidebar-footer">' + logLink + '</div>' : '') +
+    '</aside>';
+  }
+
+  // ---- Landing (renders index.md) ----
+
+  async function loadLanding(id) {
+    try {
+      var w = await api('/api/wikis/' + encodeURIComponent(id));
+      if (!w) {
