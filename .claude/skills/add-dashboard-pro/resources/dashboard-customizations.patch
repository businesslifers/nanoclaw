+    .wk-body ul, .wk-body ol { padding-left: 24px; }
+    .wk-body li { margin: 2px 0; }
+  </style>
+  `);
+}
diff --git a/dist/ui/wiki-render.js b/dist/ui/wiki-render.js
new file mode 100644
index 0000000000000000000000000000000000000000..020f9ff064a34f67526c453053122b82e6b153d0
--- /dev/null
+++ b/dist/ui/wiki-render.js
@@ -0,0 +1,180 @@
+// dist/ui/wiki-render.js
+import { Marked } from 'marked';
+
+/**
+ * Renders a markdown string for the given wiki. Internal links to other
+ * .md files (relative paths like "../summaries/foo.md") are rewritten to
+ *   /dashboard/wikis/<wikiId>/page?path=<resolvedRelPath>
+ *
+ * `pagePath` is the wiki-relative path of the page being rendered, e.g.
+ * "concepts/foo.md" — used to resolve relative links.
+ *
+ * If the markdown begins with YAML frontmatter, the recognised fields
+ * (verdict, evaluated, updated, source, url, tags) are surfaced as a
+ * metadata bar prepended to the rendered HTML. Other fields are ignored.
+ */
+export function renderWikiMarkdown(markdown, wikiId, pagePath) {
+  const { data, content } = parseFrontmatter(markdown);
+
+  const m = new Marked({ gfm: true, breaks: false });
+
+  m.use({
+    walkTokens(token) {
+      if (token.type !== 'link') return;
+      const href = token.href || '';
+      if (/^[a-z]+:\/\//i.test(href) || href.startsWith('#') || href.startsWith('mailto:')) {
+        return;
+      }
+      if (!href.endsWith('.md')) return;
+      const resolved = resolveRel(pagePath, href);
+      if (!resolved) return;
+      token.href =
+        '/dashboard/wikis/' +
+        encodeURIComponent(wikiId) +
+        '/page?path=' +
+        encodeURIComponent(resolved);
+    },
+  });
+
+  return renderMetaBar(data) + m.parse(content);
+}
+
+/**
+ * Resolves a markdown-relative href against pagePath. Returns null if
+ * the result escapes the wiki root (begins with "../" after resolution).
+ */
+function resolveRel(pagePath, href) {
+  const baseSegs = pagePath.split('/').slice(0, -1); // drop filename
+  const hrefSegs = href.split('/');
+  const stack = baseSegs.slice();
+  for (const seg of hrefSegs) {
+    if (seg === '' || seg === '.') continue;
+    if (seg === '..') {
+      if (stack.length === 0) return null;
+      stack.pop();
+    } else {
+      stack.push(seg);
+    }
+  }
+  return stack.join('/');
+}
+
+// ── Minimal YAML frontmatter parser ──────────────────────────────────────
+// Handles the subset we surface: scalar key:value, inline arrays
+// (`tags: [a, b, "c"]`), and block-style sequences (`- item` lines).
+// Anything else is ignored. Values may be quoted with single or double
+// quotes; quotes are stripped.
+
+function parseFrontmatter(md) {
+  const m = md.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?/);
+  if (!m) return { data: {}, content: md };
+  const data = parseSimpleYaml(m[1]);
+  const content = md.slice(m[0].length);
+  return { data, content };
+}
+
+function parseSimpleYaml(text) {
+  const out = {};
+  const lines = text.split(/\r?\n/);
+  let currentKey = null;
+  let currentList = null;
+  for (const line of lines) {
+    if (!line.trim() || line.trim().startsWith('#')) continue;
+    const seqMatch = line.match(/^\s*-\s+(.*)$/);
+    if (seqMatch && currentList) {
+      currentList.push(stripQuotes(seqMatch[1].trim()));
+      continue;
+    }
+    const kv = line.match(/^([A-Za-z_][A-Za-z0-9_-]*)\s*:\s*(.*)$/);
+    if (!kv) continue;
+    const key = kv[1];
+    const rawVal = kv[2].trim();
+    if (rawVal === '') {
+      currentKey = key;
+      currentList = [];
+      out[key] = currentList;
+      continue;
+    }
+    currentKey = null;
+    currentList = null;
+    if (rawVal.startsWith('[') && rawVal.endsWith(']')) {
+      out[key] = rawVal
+        .slice(1, -1)
+        .split(',')
+        .map((s) => stripQuotes(s.trim()))
+        .filter(Boolean);
+    } else {
+      out[key] = stripQuotes(rawVal);
+    }
+  }
+  return out;
+}
+
+function stripQuotes(s) {
+  if ((s.startsWith('"') && s.endsWith('"')) || (s.startsWith("'") && s.endsWith("'"))) {
+    return s.slice(1, -1);
+  }
+  return s;
+}
+
+// ── Metadata bar ─────────────────────────────────────────────────────────
+
+function escapeHtml(s) {
+  return String(s == null ? '' : s)
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&#39;');
+}
+
+function isHttpUrl(s) {
+  return typeof s === 'string' && /^https?:\/\//i.test(s);
+}
+
+function renderMetaBar(data) {
+  const parts = [];
+
+  const verdict = data.verdict;
+  if (verdict === 'worth-exploring') {
+    parts.push('<span class="wk-verdict wk-verdict-pass">✅ Worth exploring</span>');
+  } else if (verdict === 'interesting-but-not-now') {
+    parts.push('<span class="wk-verdict wk-verdict-maybe">⏸️ Interesting but not now</span>');
+  } else if (verdict === 'pass') {
+    parts.push('<span class="wk-verdict wk-verdict-fail">❌ Pass</span>');
+  }
+
+  if (data.evaluated) {
+    parts.push('<span class="wk-meta-item">Evaluated: ' + escapeHtml(data.evaluated) + '</span>');
+  }
+  if (data.updated) {
+    parts.push('<span class="wk-meta-item">Updated: ' + escapeHtml(data.updated) + '</span>');
+  }
+
+  // Source link: prefer `url:` for the href, fall back to `source:` if it
+  // looks like a URL. If `source:` is a non-URL label and `url:` is set,
+  // use the label as the link text.
+  const url = isHttpUrl(data.url) ? data.url : isHttpUrl(data.source) ? data.source : null;
+  if (url) {
+    const label = data.source && !isHttpUrl(data.source) ? data.source : 'Source';
+    parts.push(
+      '<a class="wk-meta-source" href="' +
+        escapeHtml(url) +
+        '" target="_blank" rel="noopener noreferrer" title="' +
+        escapeHtml(label) +
+        '">' +
+        escapeHtml(label) +
+        ' ↗</a>'
+    );
+  } else if (data.source) {
+    parts.push('<span class="wk-meta-item">Source: ' + escapeHtml(data.source) + '</span>');
+  }
+
+  const tags = Array.isArray(data.tags) ? data.tags : [];
+  for (const t of tags) {
+    if (t) parts.push('<span class="wk-tag">' + escapeHtml(t) + '</span>');
+  }
+
+  if (parts.length === 0) return '';
+  return '<div class="wk-meta">' + parts.join('') + '</div>';
+}
