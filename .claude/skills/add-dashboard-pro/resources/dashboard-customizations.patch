+              '<span class="wk-stat-sep">·</span>' +
+              '<span class="wk-stat">' + pluralPages(w.pageCount) + '</span>' +
+            '</div>' +
+          '</div>' +
+        '</div>' +
+      '</header>'
+    );
+  }
+
+  function renderGlance(w) {
+    return (
+      '<aside class="wk-glance">' +
+        '<h2 class="wk-glance-title">At a glance</h2>' +
+        '<dl class="wk-glance-grid">' +
+          '<div class="wk-glance-item">' +
+            '<dt>Visibility</dt><dd>' + esc(visibilityLabel(w)) + '</dd>' +
+          '</div>' +
+          '<div class="wk-glance-item">' +
+            '<dt>Pages</dt><dd>' + pluralPages(w.pageCount) + '</dd>' +
+          '</div>' +
+          '<div class="wk-glance-item">' +
+            '<dt>Last updated</dt><dd>' + esc(fmtDate(w.lastModified)) + '</dd>' +
+          '</div>' +
+          '<div class="wk-glance-item">' +
+            '<dt>Source</dt><dd><code>' + esc(w.rootAbsPath || '—') + '</code></dd>' +
+          '</div>' +
+        '</dl>' +
+      '</aside>'
+    );
+  }
+
+  // ---- Sidebar ----
+
+  function renderSidebar(w, currentPath) {
+    var accent = colorFor(w.id);
+    var hasLog = (w.tree || []).some(function(n){ return n.kind === 'file' && n.relPath === 'log.md'; });
+
+    function nodeHtml(n) {
+      if (n.kind === 'dir') {
+        var inner = (n.children || []).map(nodeHtml).join('');
+        return '<details class="wk-tree-dir" open>' +
+          '<summary>' + esc(n.relPath.split('/').pop()) + '</summary>' +
