+  // ---- Code block copy buttons ----
+
+  function attachCopyButtons() {
+    var pres = document.querySelectorAll('.wk-body pre');
+    for (var i = 0; i < pres.length; i++) {
+      var pre = pres[i];
+      if (pre.querySelector(':scope > .wk-copy-btn')) continue;
+      var btn = document.createElement('button');
+      btn.type = 'button';
+      btn.className = 'wk-copy-btn';
+      btn.textContent = 'Copy';
+      btn.setAttribute('aria-label', 'Copy code to clipboard');
+      btn.addEventListener('click', (function (target, button) {
+        return function () {
+          var code = target.querySelector('code');
+          var text = (code ? code.innerText : target.innerText).replace(/\n$/, '');
+          var done = function () {
+            button.textContent = 'Copied!';
+            button.classList.add('wk-copy-btn-done');
+            setTimeout(function () {
+              button.textContent = 'Copy';
+              button.classList.remove('wk-copy-btn-done');
+            }, 1500);
+          };
+          if (navigator.clipboard && navigator.clipboard.writeText) {
+            navigator.clipboard.writeText(text).then(done, function () {});
+          }
+        };
+      })(pre, btn));
+      pre.appendChild(btn);
+    }
+  }
