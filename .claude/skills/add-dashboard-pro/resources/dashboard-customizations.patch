+        '<div class="task-drawer-edit-actions">' +
+          '<button type="button" class="task-drawer-save" id="task-drawer-cron-save">Save</button>' +
+          '<button type="button" class="task-drawer-cancel-edit" id="task-drawer-cron-cancel">Cancel</button>' +
+          '<span class="task-drawer-error" id="task-drawer-cron-error"></span>' +
+        '</div>';
+      var input = document.getElementById('task-drawer-cron-input');
