+          '<button class="ag-name-edit-cancel" type="button" title="Cancel">&#x2715;</button>' +
+          '<span class="ag-name-edit-status" data-rename-status></span>' +
+        '</form>';
+
+      var form   = wrap.querySelector('form');
+      var input  = wrap.querySelector('.ag-name-edit-input');
+      var status = wrap.querySelector('[data-rename-status]');
+      var cancel = wrap.querySelector('.ag-name-edit-cancel');
+      input.focus();
+      input.select();
+
+      function exit() {
+        wrap.dataset.editing = '';
+        wrap.innerHTML =
+          '<a class="' + esc(anchorClass) + '" href="/dashboard/agent-groups?id=' + esc(id) + '">' + esc(input.value || current) + '</a>' +
+          ' <button class="ag-name-edit-btn" type="button" data-rename-id="' + esc(id) +
+            '" data-rename-current="' + esc(input.value || current) + '" data-rename-anchor="' + esc(anchorClass) + '" title="Rename" aria-label="Rename">&#x270E;</button>';
+      }
+
+      cancel.addEventListener('click', function() { exit(); });
+      input.addEventListener('keydown', function(ev) {
+        if (ev.key === 'Escape') { ev.preventDefault(); exit(); }
+      });
+      form.addEventListener('submit', async function(ev) {
+        ev.preventDefault();
+        var newName = (input.value || '').trim();
+        if (!newName) { status.textContent = 'Name required'; return; }
+        if (newName === current) { exit(); return; }
+        status.textContent = 'Saving…';
+        status.style.color = '#94a3b8';
+        try {
+          var result = await mutate('PATCH', '/api/agent-groups/' + encodeURIComponent(id), { name: newName });
+          input.value = (result && result.after && result.after.name) || newName;
+          status.textContent = 'Saved';
+          status.style.color = '#34d399';
+          setTimeout(function() { exit(); }, 350);
+        }
+        catch (err) {
+          status.textContent = err && err.message ? err.message : 'Error';
+          status.style.color = '#f87171';
+        }
+      });
+    }
     </script>
   `);
 }
