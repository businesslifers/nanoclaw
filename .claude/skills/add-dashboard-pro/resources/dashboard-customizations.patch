+  // All templated values are passed through esc() before being concatenated.
+  // The only unescaped insertion is the page HTML returned by /api/wikis/.../page,
+  // which is server-rendered through marked.
+  (async () => {
+    const params = new URLSearchParams(location.search);
+    const id = params.get('id');
+    const pagePath = params.get('path');
+    if (id && pagePath) return loadPage(id, pagePath);
+    if (id) return loadLanding(id);
+    return loadList();
+  })();
+
+  function esc(s) {
+    return String(s == null ? '' : s)
+      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
+      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
+  }
+
+  function rel(iso) {
+    if (!iso) return '—';
+    var t = new Date(iso).getTime();
+    if (isNaN(t)) return '—';
+    var d = Math.floor((Date.now() - t) / 1000);
+    if (d < 60) return d + 's ago';
+    if (d < 3600) return Math.floor(d/60) + 'm ago';
+    if (d < 86400) return Math.floor(d/3600) + 'h ago';
+    return Math.floor(d/86400) + 'd ago';
+  }
+
+  function fmtDate(iso) {
+    if (!iso) return '—';
+    var d = new Date(iso);
+    if (isNaN(d.getTime())) return '—';
+    var y = d.getFullYear();
+    var m = String(d.getMonth() + 1).padStart(2, '0');
+    var day = String(d.getDate()).padStart(2, '0');
+    var hh = String(d.getHours()).padStart(2, '0');
+    var mm = String(d.getMinutes()).padStart(2, '0');
+    return y + '-' + m + '-' + day + ' ' + hh + ':' + mm;
+  }
+
+  // Deterministic hash → 1 of 6 accent colors. FNV-1a over the wiki id.
+  var WK_PALETTE = ['#67e8f9', '#a78bfa', '#fbbf24', '#f472b6', '#34d399', '#38bdf8'];
+  function colorFor(id) {
+    var h = 2166136261;
+    var s = String(id);
+    for (var i = 0; i < s.length; i++) {
+      h ^= s.charCodeAt(i);
+      h = Math.imul(h, 16777619);
+    }
+    return WK_PALETTE[Math.abs(h | 0) % WK_PALETTE.length];
+  }
+  function monoLetter(title) {
+    var t = String(title || '').trim();
+    return t ? t.charAt(0).toUpperCase() : '?';
+  }
+
+  async function api(p) {
+    var headers = {};
+    var token = (document.querySelector('meta[name="dashboard-token"]') || {}).content || '';
+    if (token) headers['Authorization'] = 'Bearer ' + token;
+    var r = await fetch(p, { credentials: 'same-origin', headers: headers });
+    if (!r.ok) throw new Error('HTTP ' + r.status);
+    var ct = r.headers.get('content-type') || '';
+    return ct.includes('application/json') ? r.json() : r.text();
+  }
+
+  function pluralPages(n) {
+    return (n === 1) ? '1 page' : (esc(n) + ' pages');
