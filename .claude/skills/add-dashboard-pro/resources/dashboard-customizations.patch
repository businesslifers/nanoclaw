+        '</div>' +
+        '<div class="task-drawer-section">' +
+          '<div class="task-drawer-field">' +
+            '<label class="task-drawer-label">Schedule</label>' +
+            '<div class="task-drawer-value" id="task-drawer-cron-value"></div>' +
+            (readonly || !t.recurrence ? '' : '<button type="button" class="task-drawer-edit-btn" id="task-drawer-cron-edit" title="Edit schedule" aria-label="Edit schedule">&#9998;</button>') +
+          '</div>' +
+        '</div>' +
+        '<div class="task-drawer-section">' +
+          '<label class="task-drawer-label">Next run</label>' +
+          '<div class="task-drawer-value">' + (t.nextRun ? esc(t.nextRun) + ' <span class="task-drawer-rel">(' + esc(timeAgo(t.nextRun, true)) + ')</span>' : '—') + '</div>' +
+        '</div>' +
+        '<div class="task-drawer-section">' +
+          '<label class="task-drawer-label">Team</label>' +
+          '<div class="task-drawer-value">' + esc(t.agentGroupName) + '</div>' +
+        '</div>' +
+        '<div class="task-drawer-section">' +
+          '<label class="task-drawer-label">Created</label>' +
+          '<div class="task-drawer-value">' + esc(t.createdAt) + '</div>' +
+        '</div>' +
+        '<div class="task-drawer-section">' +
+          '<label class="task-drawer-label">Tries</label>' +
+          '<div class="task-drawer-value">' + (t.tries || 0) + '</div>' +
+        '</div>';
+
+      // Fill in the prompt and cron values.
+      var promptVal = document.getElementById('task-drawer-prompt-value');
+      if (promptVal) {
+        if (fullPrompt) {
+          promptVal.classList.add('task-drawer-prompt-rendered');
+          promptVal.innerHTML = renderMarkdown(fullPrompt);
+        } else {
+          promptVal.textContent = '(empty)';
+        }
+      }
+      var cronVal = document.getElementById('task-drawer-cron-value');
+      if (cronVal) {
+        if (t.recurrence) {
