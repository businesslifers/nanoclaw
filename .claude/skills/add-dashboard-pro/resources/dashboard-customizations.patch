+        if (state.tasks[i].id === taskId) return state.tasks[i];
+      }
+      return null;
+    }
+
+    // ── Drawer ────────────────────────────────────────────────────────
+
+    function renderDrawerScaffold() {
+      return '<div class="task-drawer-backdrop" id="task-drawer-backdrop" hidden></div>' +
+        '<aside class="task-drawer" id="task-drawer" hidden aria-modal="true" role="dialog" tabindex="-1">' +
+          '<header class="task-drawer-header">' +
+            '<h3 id="task-drawer-title">Task</h3>' +
+            '<button type="button" class="task-drawer-close" id="task-drawer-close" aria-label="Close">&#10005;</button>' +
+          '</header>' +
+          '<div class="task-drawer-body" id="task-drawer-body"></div>' +
+          '<footer class="task-drawer-footer" id="task-drawer-footer"></footer>' +
+        '</aside>';
+    }
+
+    function wireDrawer() {
+      var close = document.getElementById('task-drawer-close');
+      var bd = document.getElementById('task-drawer-backdrop');
+      if (close) close.addEventListener('click', closeDrawer);
+      if (bd) bd.addEventListener('click', closeDrawer);
+      document.addEventListener('keydown', function(ev) {
+        if (ev.key === 'Escape' && state.drawerTaskId) closeDrawer();
+      });
+    }
+
+    function openDrawer(taskId) {
+      var t = findTask(taskId);
+      if (!t) return;
+      state.drawerTaskId = taskId;
+      var drawer = document.getElementById('task-drawer');
+      var bd = document.getElementById('task-drawer-backdrop');
+      drawer.hidden = false;
+      bd.hidden = false;
+      // Force layout then add the open class so the slide-in transition runs.
+      requestAnimationFrame(function() {
+        drawer.classList.add('open');
+        bd.classList.add('open');
+      });
+      paintDrawer(t);
+      setTimeout(function() { drawer.focus(); }, 50);
+    }
+
+    function refreshDrawer() {
+      if (!state.drawerTaskId) return;
+      var t = findTask(state.drawerTaskId);
+      if (!t) { closeDrawer(); return; }
+      paintDrawer(t);
+    }
+
+    function paintDrawer(t) {
+      var titleEl = document.getElementById('task-drawer-title');
+      var bodyEl = document.getElementById('task-drawer-body');
+      var footEl = document.getElementById('task-drawer-footer');
+      var readonly = t.status === 'processing';
+
+      var fullPrompt = t.prompt || t.promptPreview || '';
+      titleEl.textContent = (fullPrompt || 'Task').slice(0, 60) + (fullPrompt.length > 60 ? '…' : '');
+
+      bodyEl.innerHTML =
+        '<div class="task-drawer-section">' +
+          '<span class="task-status-badge task-status-' + esc(t.status) + '">' + esc(t.status) + '</span>' +
+          (t.recurrence ? '' : '<span class="task-badge task-badge-oneshot" style="margin-left:8px">one-shot</span>') +
+          (t.scriptPresent ? '<span class="task-badge task-badge-script" style="margin-left:8px">has script</span>' : '') +
+        '</div>' +
