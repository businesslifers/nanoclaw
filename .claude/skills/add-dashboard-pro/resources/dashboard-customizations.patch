+      var cls = (n.relPath === currentPath) ? 'wk-tree-file wk-tree-file-active' : 'wk-tree-file';
+      return '<a class="' + cls + '" href="/dashboard/wikis?id=' +
+        encodeURIComponent(w.id) + '&path=' + encodeURIComponent(n.relPath) + '">' +
