+++ b/dist/ui/pages/tasks.js
@@ -0,0 +1,921 @@
+import { layout } from '../layout.js';
+/**
+ * /dashboard/tasks — every active scheduled task across all sessions.
+ *
+ * Shell renders client-side. The shell calls /api/tasks (already
+ * permission-filtered server-side via canAccessAgentGroup) to get its
+ * data, groups by agentGroupId, and presents collapsible sections
+ * with toolbars + a side drawer for inline edit.
+ *
+ * cronstrue is loaded server-side and exposed to the client via a
+ * pre-rendered <script> tag (no separate bundle / no dynamic import
+ * — fits the existing dashboard's single-file SSR style). The page
+ * uses cronstrue for human-readable cron text in both the table cell
+ * and the drawer's live preview.
+ */
+import cronstrue from 'cronstrue';
+/**
+ * Markdown→HTML for task prompts (escape-first; safe for innerHTML).
+ * Defined at module scope and interpolated into the page via
+ * `${renderMarkdown.toString()}` so its regex literals reach the browser
+ * verbatim — embedding it directly in the template literal would have
+ * the host's template parser strip backslashes (\d→d, \n→newline) and
+ * break the regex literals before the browser ever sees them.
+ */
+function renderMarkdown(src) {
+    if (!src) return '';
+    function escHtml(s) {
+        return String(s)
+            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
+            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
+    }
+    var BT = String.fromCharCode(96);
+    var fenceRe = new RegExp(BT + BT + BT + '([a-zA-Z0-9_+-]*)\\n([\\s\\S]*?)' + BT + BT + BT, 'g');
+    var inlineRe = new RegExp(BT + '([^' + BT + '\\n]+)' + BT, 'g');
+    var blocks = [], inlines = [];
+    src = src.replace(fenceRe, function(_m, _lang, code) {
+        blocks.push('<pre class="md-pre"><code>' + escHtml(code.replace(/\n$/, '')) + '</code></pre>');
+        return '__MD_F_' + (blocks.length - 1) + '__';
+    });
+    src = src.replace(inlineRe, function(_m, code) {
+        inlines.push('<code class="md-code">' + escHtml(code) + '</code>');
+        return '__MD_I_' + (inlines.length - 1) + '__';
+    });
+    src = escHtml(src);
+    src = src.replace(/^(#{1,6})[ \t]+(.+?)[ \t]*$/gm, function(_m, h, text) {
+        return '<h' + h.length + ' class="md-h' + h.length + '">' + text + '</h' + h.length + '>';
+    });
+    src = src.replace(/\*\*([^\*\n]+?)\*\*/g, '<strong>$1</strong>');
+    src = src.replace(/__([^_\n]+?)__/g, '<strong>$1</strong>');
+    src = src.replace(/\*([^\*\n]+?)\*/g, '<em>$1</em>');
+    src = src.replace(/(^|[^a-zA-Z0-9])_([^_\n]+?)_(?=$|[^a-zA-Z0-9])/g, '$1<em>$2</em>');
+    src = src.replace(/\[([^\]\n]+)\]\(([^)\s]+)\)/g, function(_m, text, url) {
+        if (!/^(https?:|mailto:|\/)/i.test(url)) return text;
+        return '<a href="' + url + '" target="_blank" rel="noopener noreferrer">' + text + '</a>';
+    });
+    src = src.replace(/(?:^[ \t]*[-*][ \t]+.+(?:\n[ \t]*[-*][ \t]+.+)*)/gm, function(block) {
+        var items = block.split(/\n/).map(function(l) { return l.replace(/^[ \t]*[-*][ \t]+/, ''); });
+        return '<ul class="md-ul">' + items.map(function(i) { return '<li>' + i + '</li>'; }).join('') + '</ul>';
+    });
+    src = src.replace(/(?:^[ \t]*\d+\.[ \t]+.+(?:\n[ \t]*\d+\.[ \t]+.+)*)/gm, function(block) {
+        var items = block.split(/\n/).map(function(l) { return l.replace(/^[ \t]*\d+\.[ \t]+/, ''); });
+        return '<ol class="md-ol">' + items.map(function(i) { return '<li>' + i + '</li>'; }).join('') + '</ol>';
+    });
+    src = src.replace(/__MD_I_(\d+)__/g, function(_m, i) { return inlines[+i]; });
+    src = src.replace(/__MD_F_(\d+)__/g, function(_m, i) { return blocks[+i]; });
+    return src.split(/\n{2,}/).map(function(b) {
+        var t = b.trim();
+        if (!t) return '';
+        if (/^<(h[1-6]|ul|ol|pre|blockquote|hr|table)/i.test(t)) return t;
+        return '<p class="md-p">' + t.replace(/\n/g, '<br>') + '</p>';
+    }).join('');
+}
+export function tasksPage() {
+    // Fetch /api/cronstrue isn't a thing; instead the cronstrue helper is
+    // loaded as a serializable module. The trick is that cronstrue ships an
+    // ESM build the dashboard server-side imports, but we need a client-side
+    // form. We solve this by exposing a small JS function which calls the
+    // dashboard's own /api/cron/parse — actually simpler: ship cronstrue's
+    // logic via a JSON-encoded helper. But the spec is clear: render with
+    // cronstrue. Here we lean on the server already having cronstrue, and
+    // expose a `/api/cron/describe?expr=...` route for the client to call.
+    // The toString result is also cached client-side per expression.
+    return layout('Tasks', '/dashboard/tasks', `
+    <div id="tasks-page" class="tasks-v2"><div class="ov-loading">Loading…</div></div>
+    <style>
+    .task-drawer-prompt-rendered { line-height: 1.55; }
+    .task-drawer-prompt-rendered .md-p { margin: 0 0 8px 0; }
+    .task-drawer-prompt-rendered .md-p:last-child { margin-bottom: 0; }
