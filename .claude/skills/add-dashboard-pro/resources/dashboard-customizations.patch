+          '<div class="wk-chrome-mono" aria-hidden="true">' + esc(monoLetter(w.title)) + '</div>' +
+          '<div class="wk-chrome-text">' +
+            '<h1 class="wk-chrome-title">' + esc(w.title) + '</h1>' +
